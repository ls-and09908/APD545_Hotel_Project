<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.senecacollege.hotel.controllers.KioskController">
   <top>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="Personal Details">
               <font>
                  <Font size="46.0" />
               </font>
            </Label>
         </children>
      </HBox>
   </top>
   <center>
      <VBox alignment="CENTER" prefHeight="740.0" prefWidth="1400.0" BorderPane.alignment="CENTER">
         <children>
            <Label text="* Indicates required field">
               <font>
                  <Font size="24.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="20.0" />
               </VBox.margin>
            </Label>
            <Label text="*Name: " />
            <Text fx:id="nameLbl" strokeType="OUTSIDE" strokeWidth="0.0" text="NameTxt" />
            <HBox alignment="CENTER" prefHeight="29.0" prefWidth="563.0">
               <children>
                  <TextField fx:id="nameTxt" minWidth="150.0" prefHeight="26.0" prefWidth="180.0" />
               </children>
            </HBox>
            <Button fx:id="updateName" mnemonicParsing="false" onAction="#onUpdateName" text="Update" />
            <Label text="Loyalty: ">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <Text fx:id="loyaltyLbl" strokeType="OUTSIDE" strokeWidth="0.0" text="LoyaltyTxt" />
            <HBox alignment="CENTER" prefHeight="0.0" prefWidth="563.0">
               <children>
                  <TextField fx:id="loyaltyTxt" minWidth="150.0" prefHeight="26.0" prefWidth="180.0" />
                  <Text fx:id="loyaltyErr" fill="RED" strokeType="OUTSIDE" strokeWidth="0.0" text="Err" />
               </children>
            </HBox>
            <HBox alignment="CENTER" prefHeight="19.0" prefWidth="1400.0">
               <children>
                  <Button fx:id="updateLoyalty" mnemonicParsing="false" onAction="#onUpdateLoyalty" text="Update">
                     <HBox.margin>
                        <Insets left="25.0" right="25.0" />
                     </HBox.margin>
                  </Button>
                  <Button fx:id="signupBtn" mnemonicParsing="false" onAction="#onSignupClick" text="Click to signup">
                     <HBox.margin>
                        <Insets left="25.0" right="25.0" />
                     </HBox.margin>
                  </Button>
               </children>
            </HBox>
            <Label text="*Phone: ">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <Text fx:id="phoneLbl" strokeType="OUTSIDE" strokeWidth="0.0" text="PhoneTxt" />
            <HBox alignment="CENTER" prefHeight="15.0" prefWidth="1400.0">
               <children>
                  <TextField fx:id="phoneTxt" minWidth="150.0" prefHeight="26.0" prefWidth="180.0" />
               </children>
            </HBox>
            <Button fx:id="updatePhone" mnemonicParsing="false" onAction="#onUpdatePhone" text="Update" />
            <Label text="*Email: ">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <Text fx:id="emailLbl" strokeType="OUTSIDE" strokeWidth="0.0" text="EmailTxt" />
            <HBox alignment="CENTER" prefHeight="6.0" prefWidth="1400.0">
               <children>
                  <TextField fx:id="emailTxt" prefWidth="180.0" />
               </children>
            </HBox>
            <Button fx:id="updateEmail" mnemonicParsing="false" onAction="#onUpdateEmail" text="Update" />
            <Label layoutX="686.0" layoutY="494.0" text="*Country ">
               <VBox.margin>
                  <Insets top="20.0" />
               </VBox.margin>
            </Label>
            <Text fx:id="countryLbl" layoutX="684.0" layoutY="526.0" strokeType="OUTSIDE" strokeWidth="0.0" text="countryTxt" />
            <HBox alignment="CENTER" layoutX="10.0" layoutY="530.0" prefHeight="6.0" prefWidth="1400.0">
               <children>
                  <Spinner fx:id="countrySpinner" prefHeight="26.0" prefWidth="373.0" />
               </children>
            </HBox>
            <Button fx:id="updateCountry" layoutX="679.0" layoutY="574.0" mnemonicParsing="false" onAction="#onUpdateCountry" text="Update" />
         </children>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Button mnemonicParsing="false" onAction="#onToRoomPress" text="Prev">
               <HBox.margin>
                  <Insets left="25.0" right="25.0" />
               </HBox.margin>
            </Button>
            <Button mnemonicParsing="false" onAction="#rulesAndRegDialog" text="Rules and Reg" />
            <Button fx:id="clientDetailsNextBtn" layoutX="10.0" layoutY="10.0" mnemonicParsing="false" onAction="#toAddonsPress" text="Next">
               <HBox.margin>
                  <Insets left="25.0" right="25.0" />
               </HBox.margin>
            </Button>
         </children>
      </HBox>
   </bottom>
</BorderPane>
