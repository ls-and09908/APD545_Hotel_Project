<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="ca.senecacollege.hotel.controllers.KioskController">
   <top>
      <Label text=" Welcome to Schotel Reservation Service " textAlignment="CENTER" BorderPane.alignment="CENTER">
         <font>
            <Font size="42.0" />
         </font>
         <padding>
            <Insets top="50.0" />
         </padding>
      </Label>
   </top>
   <right>
      <VBox alignment="CENTER" prefHeight="790.0" prefWidth="270.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="nextSlideBtn" mnemonicParsing="false" onAction="#nextSlidePress" text="Next" textAlignment="CENTER">
               <VBox.margin>
                  <Insets bottom="50.0" />
               </VBox.margin>
            </Button>
            <Button fx:id="prevSlideBtn" mnemonicParsing="false" onAction="#prevSlidePress" text="Prev" />
         </children>
      </VBox>
   </right>
   <bottom>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="feedbackBtn" layoutX="710.0" layoutY="18.0" mnemonicParsing="false" onAction="#onFeedbackPress" prefHeight="84.0" prefWidth="368.0" text="Feedback" textAlignment="CENTER">
               <HBox.margin>
                  <Insets left="25.0" right="25.0" />
               </HBox.margin></Button>
            <Button mnemonicParsing="false" onAction="#toKiosk" prefHeight="84.0" prefWidth="368.0" text="Continue to Booking" textAlignment="CENTER">
               <HBox.margin>
                  <Insets left="25.0" right="25.0" />
               </HBox.margin></Button>
            <Button fx:id="adminLoginBtn" layoutX="526.0" layoutY="18.0" mnemonicParsing="false" onAction="#onAdminLoginPress" prefHeight="84.0" prefWidth="368.0" text="Admin login" textAlignment="CENTER">
               <HBox.margin>
                  <Insets left="25.0" right="25.0" />
               </HBox.margin></Button>
         </children>
      </HBox>
   </bottom>
   <left>
      <VBox alignment="CENTER" prefHeight="690.0" prefWidth="226.0" BorderPane.alignment="CENTER">
         <children>
            <Button fx:id="rulesBtn" mnemonicParsing="false" onAction="#rulesAndRegDialog" prefHeight="327.0" prefWidth="182.0" text="Rules and Regulations" textAlignment="CENTER" wrapText="true">
               <font>
                  <Font size="26.0" />
               </font>
            </Button>
         </children>
      </VBox>
   </left>
   <center>
      <VBox alignment="CENTER" prefHeight="583.0" prefWidth="904.0" style="-fx-background-color: grey; -fx-border-color: black; -fx-border-image-width: 5;" BorderPane.alignment="CENTER">
         <children>
            <ImageView fx:id="diagramImage" fitHeight="300.0" fitWidth="450.0" pickOnBounds="true" preserveRatio="true" />
             <Label fx:id="diagramLbl" alignment="CENTER" text="Begin by selecting the number of guests.">
               <font>
                  <Font size="36.0" />
               </font></Label>
         </children>
      </VBox>
   </center>
</BorderPane>
